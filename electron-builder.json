{
  "appId": "dev.lstack.app",
  "productName": "LStack",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist-electron/**/*",
    "dist/**/*",
    "package-registry.json"
  ],
  "asar": true,
  "extraResources": [
    "package-registry.json",
    { "from": "icon.png", "to": "icon.png" }
  ],
  "asarUnpack": [
    "node_modules/node-pty/**/*"
  ],
  "win": {
    "icon": "icon.png",
    "target": [
      "dir"
    ]
  },
  "linux": {
    "icon": "icon.png",
    "target": [
      "deb",
      "rpm",
      "AppImage"
    ],
    "category": "Development",
    "maintainer": "LStack <contact@lstack.dev>"
  },
  "npmRebuild": false,
  "buildDependenciesFromSource": false
}
